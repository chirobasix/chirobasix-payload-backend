# ─── Payload core ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace_with_random_32+_char_string

# ─── Database (Supabase Postgres — dedicated chirobasix-payload project) ───
# Format: postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true
DATABASE_URI=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Cloudflare R2 (S3-compatible) for media uploads ─────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chirobasix-website-media
R2_PUBLIC_URL=https://pub-775c1dfa3c1d4d87a9ab5cb6170e6772.r2.dev
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ─── Public site URL (for livePreview links from admin) ──────────────
# Flip to https://chirobasix.com after DNS cutover (Phase E Part 2).
NEXT_PUBLIC_SITE_URL=https://chirobasix-website.pages.dev
